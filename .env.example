# CCAG Delivery — Environment Variables
# Copy to .env and fill in real values before deploying via Coolify

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=ccag
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=carbon_platform

# ── Clerk Auth (shared across Dashboard + Contract Hub) ──────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_FRONTEND_API_URL=https://clerk.your-domain.com
CLERK_WEBHOOK_SECRET=whsec_...
CLERK_JWT_ISSUER=https://clerk.your-domain.com

# ── Service-to-service internal token ────────────────────────────────────────
INTERNAL_API_TOKEN=generate-a-strong-random-string-here

# ── Orchestrator ─────────────────────────────────────────────────────────────
ORCHESTRATOR_DATABASE_URL=postgresql+asyncpg://ccag:replace-with-strong-password@postgres:5432/carbon_platform
REDIS_URL=redis://redis:6379/0
RAG_FIXED_TENANT_ID=default
CORS_ALLOWED_ORIGINS=https://intelligencehub.cloud,https://app.intelligencehub.cloud
AUTO_CREATE_TABLES=false

# Docker provisioning (set true only if running on a Docker host with socket access)
DOCKER_ENABLED=false

# ── Adapter / LLM Routing ────────────────────────────────────────────────────
ADAPTER_DATABASE_URL=postgresql+asyncpg://ccag:replace-with-strong-password@postgres:5432/carbon_platform
ORCHESTRATOR_URL=http://orchestrator:8000
LLM_PROVIDER=openai
LLM_API_KEY=sk-...
LLM_MODEL_NAME=gpt-4o-mini
LLM_BASE_URL=http://adapter:8000
AGENT_API_URL=http://adapter:8000
DEFAULT_LIFETIME_HOURS=24

# DGX local endpoints (optional — used when routing_mode=cost_optimized)
DGX_SPARK_1_URL=http://dgx-spark-1:5000/v1
DGX_SPARK_2_URL=http://dgx-spark-2:5000/v1

# ── Contract Hub ─────────────────────────────────────────────────────────────
CONTRACT_HUB_DATABASE_URL=postgresql://ccag:replace-with-strong-password@postgres:5432/contracthub
CONTRACT_HUB_URL=http://contract-hub:3000
RAG_GATEWAY_URL=http://orchestrator:8000
VECTOR_STORE_URL=http://vector-store:8000

# Inngest (background jobs for document ingestion)
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=local

# ── Dashboard ────────────────────────────────────────────────────────────────
ADAPTER_URL=http://adapter:8000

# ── CCAG Workspace (OpenWork Agent + OpenCode Engine) ────────────────────────
CCAG_TOKEN=generate-a-strong-random-string-here
CCAG_HOST_TOKEN=generate-a-strong-random-string-here
CCAG_APPROVAL_MODE=manual
CCAG_PUBLIC_HOST=localhost

# CCAG Workspace UI public host (for Vite allowedHosts)
CCAG_WORKSPACE_UI_URL=http://ccag-workspace-ui:3003
