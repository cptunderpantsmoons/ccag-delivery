{
  "name": "@different-ai/ccag-workspace",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "CCAG_DEV_MODE=1 pnpm --filter @ccag/desktop dev",
    "dev:server-v2": "node scripts/dev-server-v2.mjs",
    "dev:server-v2:server": "node scripts/dev-server-v2.mjs --no-app",
    "dev:windows": ".\\scripts\\dev-windows.cmd",
    "dev:windows:x64": ".\\scripts\\dev-windows.cmd x64",
    "dev:ui": "CCAG_DEV_MODE=1 pnpm --filter @ccag/app dev",
    "dev:ui-demo": "pnpm --filter @ccag/ui-demo dev",
    "dev:story": "CCAG_DEV_MODE=1 pnpm --filter @ccag/story-book dev",
    "dev:web": "CCAG_DEV_MODE=1 pnpm --filter @ccag-ee/den-web dev",
    "dev:web-local": "pnpm dev:den-local",
    "dev:den-local": "node scripts/dev-local.mjs",
    "dev:den-docker": "bash packaging/docker/den-dev-up.sh",
    "dev:headless-web": "CCAG_DEV_MODE=1 bun scripts/dev-headless-web.ts",
    "build": "node scripts/build.mjs",
    "build:ui": "pnpm --filter @ccag/app build",
    "build:web": "pnpm --filter @ccag-ee/den-web build",
    "preview": "pnpm --filter @ccag/app preview",
    "sdk:generate": "pnpm --filter ccag-server-v2 openapi:generate && pnpm --filter @ccag/server-sdk generate",
    "sdk:watch": "pnpm --filter @ccag/server-sdk watch",
    "contract:check": "node scripts/check-server-v2-contract.mjs",
    "typecheck": "pnpm run sdk:generate && pnpm --filter @ccag/app typecheck",
    "test:health": "pnpm --filter @ccag/app test:health",
    "test:sessions": "pnpm --filter @ccag/app test:sessions",
    "test:refactor": "pnpm --filter @ccag/app test:refactor",
    "test:events": "pnpm --filter @ccag/app test:events",
    "test:todos": "pnpm --filter @ccag/app test:todos",
    "test:permissions": "pnpm --filter @ccag/app test:permissions",
    "test:session-error-recovery": "pnpm --filter @ccag/app test:session-error-recovery",
    "test:session-scope": "pnpm --filter @ccag/app test:session-scope",
    "test:session-switch": "pnpm --filter @ccag/app test:session-switch",
    "test:fs-engine": "pnpm --filter @ccag/app test:fs-engine",
    "test:e2e": "pnpm --filter @ccag/app test:e2e",
    "test:orchestrator": "pnpm --filter ccag-orchestrator test:router",
    "bump:patch": "pnpm --filter @ccag/app bump:patch",
    "bump:minor": "pnpm --filter @ccag/app bump:minor",
    "bump:major": "pnpm --filter @ccag/app bump:major",
    "bump:set": "pnpm --filter @ccag/app bump:set",
    "release:review": "node scripts/release/review.mjs",
    "release:prepare": "node scripts/release/prepare.mjs",
    "release:prepare:dry": "node scripts/release/prepare.mjs --dry-run",
    "release:ship": "node scripts/release/ship.mjs",
    "release:ship:watch": "node scripts/release/ship.mjs --watch",
    "tauri": "pnpm --filter @ccag/desktop exec tauri"
  },
  "devDependencies": {
    "turbo": "^2.5.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@whiskeysockets/baileys",
      "better-sqlite3",
      "electron",
      "esbuild",
      "protobufjs"
    ],
    "patchedDependencies": {
      "@solidjs/router@0.15.4": "patches/@solidjs__router@0.15.4.patch"
    }
  },
  "packageManager": "pnpm@10.27.0"
}
